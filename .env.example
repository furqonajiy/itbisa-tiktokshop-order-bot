# Template for local testing only.
# Copy this to .env and fill in real values. Never commit .env to git.
#
# In production (GitHub Actions), these are set as repository Secrets instead.
#
# TikTok Shop tokens are stored in data/tiktokshop_tokens.json and are managed
# automatically by the bot after bootstrap.

TIKTOKSHOP_APP_KEY=your_app_key_here
TIKTOKSHOP_APP_SECRET=your_app_secret_here
TIKTOKSHOP_SHOP_ID=your_shop_id_here

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789

# Set to "true" to use canned fake orders instead of calling TikTok Shop.
# Useful for local testing when live access is not available.
# Leave this empty or "false" in production.
USE_FAKE_TIKTOKSHOP=false
